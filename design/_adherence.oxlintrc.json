{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/letters/**",
              "components/reading/**",
              "ui_kits/mitlesen-mobile/**",
              "ui_kits/mitlesen-reader/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Songti SC|Cormorant Garamond|DM Sans|Noto Serif SC))/i]",
        "message": "Font not provided by the design system. Available: Songti SC, Cormorant Garamond, DM Sans, Noto Serif SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|gold|rose|plain)$/]",
        "message": "<Badge> tone must be one of 'accent' | 'gold' | 'rose' | 'plain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BookCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|author|read|total|annotationCount|active|onDelete|key|ref|className|style|children)$/]",
        "message": "<BookCard> doesn't accept that prop. Declared props: title, author, read, total, annotationCount, active, onDelete."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|block|icon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, block, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|primary|done)$/]",
        "message": "<Button> variant must be one of 'default' | 'primary' | 'done'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChapterRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|read|current|annotationCount|key|ref|className|style|children)$/]",
        "message": "<ChapterRow> doesn't accept that prop. Declared props: title, read, current, annotationCount."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:seal|children|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: seal, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute > JSXIdentifier[name!=/^(?:by|active|children|key|ref|className|style|children)$/]",
        "message": "<Highlight> doesn't accept that prop. Declared props: by, active, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Highlight'] > JSXAttribute[name.name='by'] > Literal[value!=/^(?:human|ai)$/]",
        "message": "<Highlight> by must be one of 'human' | 'ai'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|bare|label|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, bare, label, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarginNote'] > JSXAttribute > JSXIdentifier[name!=/^(?:persona|personaName|quote|open|active|replyCount|onReply|replies|children|key|ref|className|style|children)$/]",
        "message": "<MarginNote> doesn't accept that prop. Declared props: persona, personaName, quote, open, active, replyCount, onReply, replies, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MarginNote'] > JSXAttribute[name.name='persona'] > Literal[value!=/^(?:ai|human)$/]",
        "message": "<MarginNote> persona must be one of 'ai' | 'human'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PersonaTag'] > JSXAttribute > JSXIdentifier[name!=/^(?:persona|name|key|ref|className|style|children)$/]",
        "message": "<PersonaTag> doesn't accept that prop. Declared props: persona, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='PersonaTag'] > JSXAttribute[name.name='persona'] > Literal[value!=/^(?:ai|human)$/]",
        "message": "<PersonaTag> persona must be one of 'ai' | 'human'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressRail'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|read|total|showLabel|key|ref|className|style|children)$/]",
        "message": "<ProgressRail> doesn't accept that prop. Declared props: value, read, total, showLabel."
      },
      {
        "selector": "JSXOpeningElement[name.name='RitualCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:art|size|name|kicker|title|subtitle|quote|note|footer|seed|children|key|ref|className|style|children)$/]",
        "message": "<RitualCard> doesn't accept that prop. Declared props: art, size, name, kicker, title, subtitle, quote, note, footer, seed, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='RitualCard'] > JSXAttribute[name.name='art'] > Literal[value!=/^(?:fold|ripple|stardust|lastfold)$/]",
        "message": "<RitualCard> art must be one of 'fold' | 'ripple' | 'stardust' | 'lastfold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RitualCard'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:compact|standard|tall)$/]",
        "message": "<RitualCard> size must be one of 'compact' | 'standard' | 'tall'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|count|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label, count."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sheet'] > JSXAttribute > JSXIdentifier[name!=/^(?:ruled|children|key|ref|className|style|children)$/]",
        "message": "<Sheet> doesn't accept that prop. Declared props: ruled, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:loading|icon|children|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: loading, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoiceStaff'] > JSXAttribute > JSXIdentifier[name!=/^(?:voice|animate|key|ref|className|style|children)$/]",
        "message": "<VoiceStaff> doesn't accept that prop. Declared props: voice, animate."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoiceStaff'] > JSXAttribute[name.name='voice'] > Literal[value!=/^(?:first|second)$/]",
        "message": "<VoiceStaff> voice must be one of 'first' | 'second'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaxDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|color|size|hollow|key|ref|className|style|children)$/]",
        "message": "<WaxDot> doesn't accept that prop. Declared props: tone, color, size, hollow."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaxDot'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|deep|rose|mint|gold|lavender|ice)$/]",
        "message": "<WaxDot> tone must be one of 'accent' | 'deep' | 'rose' | 'mint' | 'gold' | 'lavender' | 'ice'."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaxSeal'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|breathe|broken|label|key|ref|className|style|children)$/]",
        "message": "<WaxSeal> doesn't accept that prop. Declared props: size, breathe, broken, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaxSeal'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:dot|sm|md|lg)$/]",
        "message": "<WaxSeal> size must be one of 'dot' | 'sm' | 'md' | 'lg'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
